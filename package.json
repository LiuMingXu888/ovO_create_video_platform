{
  "name": "ovo-create-video-platform",
  "productName": "ovO",
  "version": "0.1.14",
  "description": "ovO desktop video creation platform",
  "private": true,
  "author": "ovO",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --strictPort",
    "dev:electron": "concurrently -k \"npm run dev\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "launch:mac": "node scripts/launch-mac.mjs",
    "install:mac-app": "node scripts/install-mac-app.mjs",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.node.json && vite build",
    "dist:win": "npm run build && electron-builder --win --x64",
    "dist:win:installer": "npm run build && electron-builder --win nsis --x64",
    "dist:win:portable": "npm run build && electron-builder --win portable --x64",
    "release:patch": "node scripts/release-patch.mjs",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "devtools": "react-devtools",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "playwright": "^1.60.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^37.10.3",
    "electron-builder": "^26.15.3",
    "js-yaml": "^4.2.0",
    "jsdom": "^25.0.1",
    "react-devtools": "7.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.ovo.create-video-platform",
    "productName": "ovO",
    "directories": {
      "output": "release/windows"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "resources/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "win": {
      "icon": "resources/ovO.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "artifactName": "${productName}-${version}-${arch}-setup.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ovO",
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "${productName}-${version}-${arch}-portable.${ext}"
    },
    "publish": {
      "provider": "generic",
      "url": "https://placeholder.example.com"
    }
  }
}
