{
  "compilerOptions": {
    "composite": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "rootDir": "electron",
    "outDir": "dist-electron",
    "tsBuildInfoFile": "dist-electron/tsconfig.node.tsbuildinfo",
    "types": ["node"]
  },
  "include": ["electron"]
}
